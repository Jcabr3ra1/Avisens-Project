# Normaliza los finales de línea en todo el repo.
# Evita conflictos y diffs ruidosos entre Windows (CRLF) y Mac/Linux (LF):
# en el repositorio siempre se guarda con LF.
* text=auto eol=lf

# Excepción: los scripts de Windows (.bat/.cmd) DEBEN conservar CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf

# Archivos binarios: git NO debe tocar sus finales de línea.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.svg   text
*.pdf   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.jar   binary

# Lockfiles y generados: no cuentan para las estadísticas de lenguaje de GitHub
# y se muestran colapsados en los diffs.
package-lock.json linguist-generated
