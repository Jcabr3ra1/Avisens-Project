generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Rol {
  id             Int      @id @default(autoincrement())
  nombre         String   @unique
  descripcion    String?
  activo         Boolean  @default(true)
  fecha_creacion DateTime @default(now())

  usuarios       Usuario[]
  roles_permisos RolPermiso[]

  @@map("roles")
}

model Permiso {
  id          Int    @id @default(autoincrement())
  codigo      String @unique
  modulo      String
  descripcion String?
  activo      Boolean @default(true)

  roles_permisos RolPermiso[]

  @@map("permisos")
}

model RolPermiso {
  id         Int @id @default(autoincrement())
  rol_id     Int
  permiso_id Int

  rol     Rol     @relation(fields: [rol_id], references: [id])
  permiso Permiso @relation(fields: [permiso_id], references: [id])

  @@unique([rol_id, permiso_id])
  @@map("roles_permisos")
}

model Usuario {
  id               Int      @id @default(autoincrement())
  rol_id           Int
  nombre_completo  String
  cedula           String   @unique
  email            String   @unique
  password_hash    String
  telefono         String?
  activo           Boolean  @default(true)
  fecha_creacion   DateTime @default(now())

  rol              Rol               @relation(fields: [rol_id], references: [id])
  seguridad_cuenta SeguridadCuenta?
  sesiones         Sesion[]
  granjas          Granja[]

  @@map("usuarios")
}

model SeguridadCuenta {
  id                            Int       @id @default(autoincrement())
  usuario_id                    Int       @unique
  intentos_fallidos             Int       @default(0)
  bloqueado_hasta               DateTime?
  fecha_ultimo_login            DateTime?
  fecha_ultimo_cambio_password  DateTime?

  usuario Usuario @relation(fields: [usuario_id], references: [id])

  @@map("seguridad_cuenta")
}

model Sesion {
  id                 Int      @id @default(autoincrement())
  usuario_id         Int
  refresh_token_hash String
  ip_origen          String?
  user_agent         String?
  expira_en          DateTime
  revocada           Boolean  @default(false)
  fecha_creacion     DateTime @default(now())

  usuario Usuario @relation(fields: [usuario_id], references: [id])

  @@map("sesiones")
}

// ---------------------------------------------------------------------------
// EP-04 · Monitoreo ambiental
// ---------------------------------------------------------------------------

model Granja {
  id             Int      @id @default(autoincrement())
  propietario_id Int
  nombre         String
  direccion      String?
  municipio      String?
  departamento   String?
  latitud        Float?
  longitud       Float?
  area_total_m2  Float?
  activa         Boolean  @default(true)
  fecha_creacion DateTime @default(now())

  propietario Usuario   @relation(fields: [propietario_id], references: [id])
  galpones    Galpon[]

  @@map("granjas")
}

model Galpon {
  id                 Int       @id @default(autoincrement())
  granja_id          Int
  codigo             String // "galpon1" — coincide con el prefijo del topic MQTT
  nombre             String
  capacidad_aves     Int?
  ancho_metros       Float?
  largo_metros       Float?
  orientacion        String?
  tipo_techo         String?
  plano_url          String?
  activo             Boolean   @default(true)
  fecha_construccion DateTime? @db.Date

  granja Granja @relation(fields: [granja_id], references: [id])

  // El código se repite entre granjas (cada una tiene su "galpon1"), pero es
  // único dentro de una misma granja.
  @@unique([granja_id, codigo])
  @@map("galpones")
}
